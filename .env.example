POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
POLYMARKET_MVP_STATE_DIR=./var
POLYMARKET_MVP_DB_PATH=./var/polymarket_mvp.sqlite3

# Shadow mode: when set to "1", poly_executor.execute_record never hits the CLOB;
# a shadow_executions row is written instead. Default off in .env.example but
# production deployments that have not yet funded a wallet should set this to 1.
MVP_SHADOW_MODE=0
# Execution mode for the autopilot execute loop ("mock" or "real").
POLY_AUTOPILOT_EXECUTE_MODE=real

CRYPTOPANIC_AUTH_TOKEN=replace-me
CRYPTOPANIC_BASE_URL=https://cryptopanic.com/api/developer/v2
APIFY_TOKEN=replace-me
APIFY_API_KEY=
PERPLEXITY_API_KEY=pplx-replace-me
PERPLEXITY_MODEL=sonar

# Tavily LLM-friendly search (paid; 1000 lifetime credits on dev tier).
# Adapter enforces per-day cap (TAVILY_DAILY_CAP, default 30 → 900/month max).
TAVILY_API_KEY=
TAVILY_DAILY_CAP=30

# The Odds API — bookmaker consensus across 40+ sportsbooks (paid; 500 free
# requests/month). Adapter enforces per-day cap (ODDS_API_DAILY_CAP, default
# 15 → 450/month max). Only fires for sports_winner / sports_totals markets
# whose teams match a known league keyword.
ODDS_API_KEY=
ODDS_API_DAILY_CAP=15

# Reddit OAuth (free with rate limits). Register a "script" app at
# https://www.reddit.com/prefs/apps to get client_id + client_secret. Without
# these the RedditAdapter silently returns [] and the rest of the pipeline
# is unaffected.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=PolyTradingUltra/0.1

POLY_RISK_MAX_ORDER_USDC=10
POLY_RISK_MIN_CONFIDENCE=0.60
POLY_RISK_MAX_SLIPPAGE_BPS=500
POLY_RISK_REQUIRE_EXECUTABLE_MARKET=true
POLY_RISK_MAX_GAMMA_CLOB_DIVERGENCE_BPS=500
POLY_MIN_TRADABLE_PRICE=0.10
POLY_MAX_TRADABLE_PRICE=0.90
POLYMARKET_AVAILABLE_BALANCE_U=100
POLY_BLOCK_CRYPTO_DIRECTIONAL_MARKETS=true
POLY_BLOCK_CRYPTO_DIRECTIONAL_MAX_EXPIRY_DAYS=7

POLY_APPROVAL_MAX_TTL_SECONDS=300
POLY_APPROVAL_EXPIRY_BUFFER_SECONDS=120
POLY_ORDER_MAX_LIVE_TTL_SECONDS=300

# Polygon RPC for on-chain reads + redeem txs. The public-node default is
# heavily rate-limited from cloud IPs (we measured 429s within seconds of a
# reconcile cycle). Strongly recommend a free-tier Alchemy / QuickNode /
# Ankr endpoint for any deployment with real positions:
#   https://polygon-mainnet.g.alchemy.com/v2/<YOUR-KEY>
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

POLY_CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137
SIGNATURE_TYPE=replace-with-0-1-or-2
FUNDER=0xreplace_me
POLY_API_KEY=replace-me
POLY_API_SECRET=replace-me
POLY_API_PASSPHRASE=replace-me
POLY_CLOB_SIGNER_KEY=replace-me
SESSION_MAX_BALANCE_USDC=1000
SESSION_MAX_SPEND_USDC=50


POLY_SCAN_INTERVAL_SECONDS=30
POLY_CONTEXT_INTERVAL_SECONDS=60
POLY_DECISION_INTERVAL_SECONDS=30
POLY_RECONCILE_INTERVAL_SECONDS=10
POLY_EXIT_INTERVAL_SECONDS=30
POLY_AUTOPILOT_MAX_CANDIDATES_PER_LOOP=25
POLY_AUTOPILOT_MAX_PROPOSALS_PER_LOOP=3
POLY_AUTOPILOT_MAX_PENDING_APPROVALS=5
POLY_AUTOPILOT_MAX_EXIT_PROPOSALS_PER_LOOP=5
POLY_SCAN_MIN_LIQUIDITY=10000
POLY_SCAN_MAX_EXPIRY_DAYS=7

# Proposer engine: "openclaw_llm" routes proposal generation through the
# decision brain (Claude Sonnet 4.6 via the `claude` CLI, see OPENCLAW_TRANSPORT
# below). Use "heuristic" for the deterministic price-momentum fallback.
POLY_PROPOSER_ENGINE=openclaw_llm

# Two-stage proposer: how many markets the heuristic pre-filter forwards to
# Sonnet each cycle. Lowering this is the single biggest lever for cutting
# cycle time (one CLI call == one serialized Sonnet invocation).
POLY_PROPOSER_LLM_CANDIDATES=8

# How many recent proposals per market to include as `prior_proposals` in
# the LLM payload. Gives Sonnet self-calibration context ("what did I say
# last time, did it fill, was I right"). Set to 0 to disable.
POLY_PROPOSER_PRIOR_DEPTH=3

# Optional override for the PolyProposer markdown workspace.
# Defaults to ~/.openclaw/workspace-polymarket-proposer/.
# POLY_PROPOSER_PROMPT_DIR=

# Optional override for the PolyExiter markdown workspace.
# Defaults to ~/.openclaw/workspace-polymarket-exiter/ (falls back to the
# embedded prompt if that directory does not exist).
# POLY_EXITER_PROMPT_DIR=

# Position sizing modes:
#   "conviction" (default): LLM emits objective fields (confidence,
#       catalyst_clarity, downside_risk); code maps deterministically to a
#       conviction tier (speculative / medium / high / extreme) and a
#       USDC size from src/polymarket_mvp/strategy/conviction.py. The
#       sizer also auto-downgrades when a position would exceed 25% of
#       the CLOB top-5 orderbook depth (slippage protection).
#   "kelly": legacy linear-Kelly scaler. Kept as a rollback escape hatch;
#       on small accounts the 5-share-per-order floor zeroes out almost
#       every proposal.
#   "off" / "flat": pass through whatever size the LLM proposed (testing).
POLY_SIZING_MODE=conviction
POLY_ORDER_MIN_USDC=1.0

# Account balance used by the conviction sizer to scale tiers as the
# account grows. Each doubling of balance over $50 doubles tier sizes
# (capped by POLY_TIER_SCALE_MAX). Update this when you fund or withdraw.
POLY_ACCOUNT_BALANCE_USDC=50
POLY_TIER_SCALE_MAX=8.0

# Minimum wall-clock seconds between LLM-backed propose cycles. The
# autopilot loop wakes more often (POLY_DECISION_INTERVAL_SECONDS) but
# only invokes the Claude CLI once per this interval, so a shared Max
# subscription with interactive sessions does not get hammered.
POLY_LLM_MIN_INTERVAL_SECONDS=600

# Decision brain: Claude Code CLI using the logged-in subscription quota.
# The machine running the autopilot must have the `claude` CLI installed and
# authenticated (run `claude setup-token` on the EC2 host once).
OPENCLAW_TRANSPORT=claude
CLAUDE_CLI_PATH=
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_TIMEOUT_SECONDS=180

# Legacy OpenClaw CLI brain (kept for easy fallback — ignored when
# OPENCLAW_TRANSPORT=claude).
OPENCLAW_CLI_PATH=$HOME/.openclaw-local/bin/openclaw
OPENCLAW_AGENT_ID=polymarket-proposer
