[Unit]
Description=Run Alpha Lab odds ingest every 90 minutes

[Timer]
# 120-min cadence = 12 ticks/day. Free tier = 500/month = ~16/day.
# One league per tick = 360 req/month with margin for retries.
# Do NOT drop below 120 min without upgrading to paid tier.
OnBootSec=3min
OnUnitActiveSec=120min
Unit=alpha-lab-odds.service
Persistent=true

[Install]
WantedBy=timers.target
